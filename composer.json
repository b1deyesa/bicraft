{
    "name": "bideyesa/bicraft",
    "description": "Bideyesa UI Library",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Imagodeo Bideyesa",
            "email": "bideyesa@gmail.com"
        }
    ],
    "require": {
        "livewire/livewire": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "Bideyesa\\Bicraft\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php artisan vendor:publish --tag=bicraft --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=bicraft --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bideyesa\\Bicraft\\BicraftServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}