{
    "name": "bideyesa/bicraft",
    "description": "UI Library",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Imagodeo Bideyesa",
            "email": "bideyesa@gmail.com"
        }
    ],
    "require": {
        "livewire/livewire": "^3.5",
        "bideyesa/bicraft": "1.0.0"
    },
    "autoload": {
        "psr-4": {
            "Bideyesa\\Bicraft\\": "."
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php artisan vendor:publish --tag=bicraft"
        ],
        "post-update-cmd": [
            "php artisan vendor:publish --tag=bicraft"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bideyesa\\Bicraft\\BicraftServiceProvider"
            ],
            "aliases": []
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}